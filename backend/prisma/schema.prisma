  id            Int           @id @default(autoincrement())
  name          String        @unique
  description   String?       @db.Text
  price         Decimal       @db.Decimal(10, 2)
  stock         Int           @default(0)
  imageUrl      String?
  gallery       Json?

  typeId        Int
  type          ProductType   @relation(fields: [typeId], references: [id])
  
