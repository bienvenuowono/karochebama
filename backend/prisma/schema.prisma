// Table de liaison entre Produits et Sites de Culture
model ProductSite {
  productId Int
  siteId    Int
  product   Product      @relation(fields: [productId], references: [id])
  site      CultureSite  @relation(fields: [siteId], references: [id])
  @@id([productId, siteId])
}

// --- MODULE : RÉCOLTES ---
model Harvest {
  id          Int            @id @default(autoincrement())
  productId   Int
  product     Product        @relation(fields: [productId], references: [id])
  siteId      Int
  site        CultureSite    @relation(fields: [siteId], references: [id])
  quantity    Float          
  unit        String         @default("kg")
  harvestDate DateTime       @default(now())
  status      String         @default("COMPLETED")
  notes       String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([productId])
  @@index([siteId])
}

